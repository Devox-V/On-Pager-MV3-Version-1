{
    "manifest_version": 3,
    "name": "On-Pager SEO Assistant",
    "version": "1.2.0",
    "description": "Visual and actionable on-page SEO analysis tool that extracts live SEO data, provides structured evaluation, and produces an overall SEO health score.",
    "minimum_chrome_version": "110",
    "permissions": [
        "activeTab",
        "scripting",
        "storage"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "On-Pager SEO",
        "default_icon": {
            "16": "icons/favicon_image.png",
            "48": "icons/favicon_image.png",
            "128": "icons/favicon_image.png"
        }
    },
    "icons": {
        "16": "icons/favicon_image.png",
        "48": "icons/favicon_image.png",
        "128": "icons/favicon_image.png"
    }
}